{
  "name": "alt1-launcher-api",
  "version": "2.0.2",
  "description": "TypeScript types and detection helpers for Alt1 Launcher apps",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "alt1",
    "alt1-launcher",
    "runescape",
    "rs3",
    "overlay",
    "hotkeys"
  ],
  "author": "Alt1GL",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  }
}
